{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug RPC Server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/rpc_server",
            "args": ["-i", "bin/test.conf"],
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug RPC Client",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/rpc_client",
            "args": ["-i", "bin/test.conf"],
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
